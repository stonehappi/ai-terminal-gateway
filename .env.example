# Gateway auth: comma-separated Bearer tokens callers must present.
# Leave empty to disable auth (development only).
GATEWAY_API_KEYS=dev-key-123

# HTTP port
PORT=8081

# Log file path. The Windows release binary is built as a GUI app (no console
# window, so a user can't close it by accident) — set this so its JSON logs are
# captured to a file instead of a (nonexistent) console. Leave empty to log to
# stdout when running from a terminal.
GATEWAY_LOG_FILE=

# Default generation CLI provider: "claude", "agy", or "codex". Callers can
# override this per request with the "provider" field. Auth comes from that
# CLI's own local login — NO ANTHROPIC_API_KEY is used.
LLM_PROVIDER=codex

# Claude Code CLI (used when LLM_PROVIDER=claude).
CLAUDE_BIN=claude
# Optional model override; leave empty for the CLI default.
CLAUDE_MODEL=

# agy CLI (used when LLM_PROVIDER=agy).
AGY_BIN=agy
# Optional model override; leave empty for the CLI default.
# List available models with `agy models`.
AGY_MODEL=

# OpenAI Codex CLI (used when LLM_PROVIDER=codex). Log in first with `codex login`.
CODEX_BIN=codex
# Optional model override; leave empty for the CLI default (e.g. gpt-5-codex).
CODEX_MODEL=

# Sandbox backend: "docker" (isolated, recommended) or "local" (dev only, NO isolation)
SANDBOX_BACKEND=docker
SANDBOX_TIMEOUT_SECONDS=30

# Docker sandbox tuning
SANDBOX_PYTHON_IMAGE=python:3.12-slim
SANDBOX_BASH_IMAGE=bash:5
SANDBOX_MEMORY=256m
SANDBOX_CPUS=1
