# Gateway auth: comma-separated Bearer tokens callers must present.
# Leave empty to disable auth (development only).
GATEWAY_API_KEYS=dev-key-123

# HTTP port
PORT=8081

# Generation CLI provider: "claude" (default) or "agy". Auth comes from that
# CLI's own local login — NO ANTHROPIC_API_KEY is used.
LLM_PROVIDER=agy

# Claude Code CLI (used when LLM_PROVIDER=claude).
CLAUDE_BIN=claude
# Optional model override; leave empty for the CLI default.
CLAUDE_MODEL=

# agy CLI (used when LLM_PROVIDER=agy).
AGY_BIN=agy
# Optional model override; leave empty for the CLI default.
# List available models with `agy models`.
AGY_MODEL=

# Sandbox backend: "docker" (isolated, recommended) or "local" (dev only, NO isolation)
SANDBOX_BACKEND=docker
SANDBOX_TIMEOUT_SECONDS=30

# Docker sandbox tuning
SANDBOX_PYTHON_IMAGE=python:3.12-slim
SANDBOX_BASH_IMAGE=bash:5
SANDBOX_MEMORY=256m
SANDBOX_CPUS=1
